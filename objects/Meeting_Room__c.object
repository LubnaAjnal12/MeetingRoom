    <allowInChatterGroups>false</allowInChatterGroups>
    <compactLayoutAssignment>SYSTEM</compactLayoutAssignment>
    <deploymentStatus>Deployed</deploymentStatus>
    <description>Custom object to store and manage meeting room information including capacity, location, and availability status.</description>
    <enableActivities>true</enableActivities>
    <enableBulkApi>true</enableBulkApi>
    <enableFeeds>false</enableFeeds>
    <enableHistory>true</enableHistory>
    <enableLicensing>false</enableLicensing>
    <enableReports>true</enableReports>
    <enableSearch>true</enableSearch>
    <enableSharing>true</enableSharing>
    <enableStreamingApi>true</enableStreamingApi>
    <externalSharingModel>Private</externalSharingModel>
    <label>Meeting Room</label>
    <nameField>
        <label>Room Name</label>
        <trackHistory>false</trackHistory>
        <type>Text</type>
    </nameField>
    <pluralLabel>Meeting Rooms</pluralLabel>
    <searchLayouts/>
    <sharingModel>ReadWrite</sharingModel>
    <visibility>Public</visibility>
    <fields>
        <fullName>Capacity__c</fullName>
        <description>Maximum number of people that can be accommodated in this meeting room.</description>
        <externalId>false</externalId>
        <inlineHelpText>Enter the total seating capacity of the meeting room.</inlineHelpText>
        <label>Capacity</label>
        <precision>4</precision>
        <required>false</required>
        <scale>0</scale>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Number</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Location__c</fullName>
        <description>Physical location or building floor where the meeting room is situated.</description>
        <externalId>false</externalId>
        <inlineHelpText>Enter the building name, floor, or wing where this room is located (e.g., Building A - 3rd Floor).</inlineHelpText>
        <label>Location</label>
        <length>255</length>
        <required>false</required>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Text</type>
        <unique>false</unique>
    </fields>
    <fields>
        <fullName>Is_Available__c</fullName>
        <defaultValue>true</defaultValue>
        <description>Indicates whether the meeting room is currently available for booking or temporarily unavailable for maintenance or other reasons.</description>
        <inlineHelpText>Check this box if the room is available for booking. Uncheck if the room is under maintenance or temporarily unavailable.</inlineHelpText>
        <label>Is Available</label>
        <trackHistory>false</trackHistory>
        <trackTrending>false</trackTrending>
        <type>Checkbox</type>
    </fields>
</CustomObject>